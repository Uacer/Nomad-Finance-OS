# ===================================
# Polymarket Trading Bot - Environment Variables
# ===================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git!

# ===================================
# 🔐 Wallet Configuration
# ===================================
# Your Ethereum private key (without 0x prefix)
PM_PRIVATE_KEY=your_private_key_here_64_hex_chars

# Your wallet address (with 0x prefix)
PM_FUNDER=0xYourWalletAddressHere

# Alternative signer address (optional, usually same as PM_FUNDER)
PM_SIGNER_ADDR=0xYourWalletAddressHere

# ===================================
# 🌐 RPC Endpoints
# ===================================
# Polygon RPC endpoint (required)
POLYGON_RPC=https://polygon-rpc.com

# ===================================
# 🔑 Polymarket CLOB API Credentials
# ===================================
# Pre-derived CLOB creds (required by entry_bot/exit_bot)
PM_CLOB_API_KEY=your_clob_api_key
PM_CLOB_API_SECRET=your_clob_api_secret
PM_CLOB_API_PASSPHRASE=your_clob_api_passphrase

# Optional: cache path for derived CLOB creds (ignored by git because it contains "credentials")
# PM_CLOB_CREDS_PATH=/root/.openclaw/secrets/clob_credentials.json

# Alternative RPCs for failover (optional)
# ALT_RPC_1=https://polygon-bor-rpc.publicnode.com
# ALT_RPC_2=https://rpc-mainnet.matic.quiknode.pro

# ===================================
# 📱 Telegram Notifications
# ===================================
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Your Telegram chat ID (message @userinfobot to get it)
TELEGRAM_CHAT_ID=123456789

# ===================================
# 🖥️ Dashboard
# ===================================
# Dashboard web interface port
DASHBOARD_PORT=8080

# Dashboard password (leave empty for no auth)
DASHBOARD_PASSWORD=your_secure_password_here

# Flask session signing key (recommended: 64+ random chars)
DASHBOARD_SECRET_KEY=replace_with_random_hex_string

# ===================================
# 🔧 Optional Settings
# ===================================
# Debug mode (true/false)
# DEBUG=false

# Log level (INFO, DEBUG, WARNING, ERROR)
# LOG_LEVEL=INFO

# ===================================
# ⚠️ Security Notes
# ===================================
# 1. Keep PM_PRIVATE_KEY secret - anyone with this can drain your wallet
# 2. Use a dedicated wallet with limited funds for trading
# 3. Never share this file or commit it to version control
# 4. Consider using a hardware wallet for large amounts
# 5. Rotate TELEGRAM_BOT_TOKEN periodically
